{
  "name": "superdoc-preview",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/server.js",
  "bin": {
    "superdoc-preview": "./dist/server.js"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "start": "tsx server.ts",
    "typecheck": "tsc --noEmit",
    "build:ts": "tsc",
    "build:binary": "bun build server.ts --compile --outfile ../bin/superdoc-preview",
    "build:assets": "mkdir -p ../bin/client ../bin/tools ../bin/node_modules/@superdoc-dev/sdk-darwin-arm64/bin && cp -r ../client/dist ../bin/client/ && cp node_modules/@superdoc-dev/sdk/tools/*.json ../bin/tools/ && cp node_modules/@superdoc-dev/sdk-darwin-arm64/bin/superdoc ../bin/node_modules/@superdoc-dev/sdk-darwin-arm64/bin/",
    "build": "npm run build:binary && npm run build:assets"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/static": "^8.0.0",
    "@fastify/websocket": "^11.1.0",
    "@superdoc-dev/sdk": "^1.1.0",
    "@superdoc-dev/superdoc-yjs-collaboration": "^1.0.0",
    "dotenv": "^16.4.7",
    "fastify": "^5.3.3",
    "superdoc": "^1.24.2",
    "yjs": "13.6.19"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.7.0"
  }
}
